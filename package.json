{
  "name": "demiurge",
  "version": "0.1.0",
  "description": "Install a Claude Code multi-agent orchestrator template into any project — agents, hooks, skills, task files, and workflow.",
  "type": "module",
  "bin": {
    "demiurge": "bin/cli.mjs"
  },
  "files": [
    "bin/",
    ".claude/",
    "docs/ARCHITECTURE.md",
    "docs/DECISIONS.md",
    "docs/MEMORY_BANK.md",

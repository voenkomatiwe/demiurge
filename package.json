{
  "name": "demiurge",
  "version": "0.2.0",
  "description": "Multi-agent AI orchestrator with optional UI dashboard",
  "type": "module",
  "bin": {
    "demiurge": "cli/src/index.ts"
  },
  "workspaces": [
    "packages/core",
    "backend",
    "frontend",
    "cli"
  ],
  "scripts": {
    "dev": "bun --filter '*' dev",
    "dev:backend": "bun --filter @demiurge/backend dev",
    "dev:frontend": "bun --filter @demiurge/frontend dev",
    "build": "bun --filter '*' build",
    "build:frontend": "bun --filter @demiurge/frontend build",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "test": "bun test",
    "typecheck": "bun --filter '*' typecheck"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "bun-types": "^1.3.12",
    "typescript": "^5.7.0"
  },
  "files": [
    "cli/",
    "packages/",
    "backend/",
    "frontend/dist/",
    "agents/",
    "scripts/run-agent.sh",
    "scripts/convert.sh",
    "CLAUDE.md",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/voenkomatiwe/claude-orchestrator.git"
  }
}
